# Copy to `.env` and customise. docker-compose reads .env automatically.

# MySQL
MYSQL_ROOT_PASSWORD=rootpw
DB_NAME=datarover

# Host port mappings (change if XAMPP/other services already use these)
APACHE_HOST_PORT=8080
SCANNER_HOST_PORT=8000
SCHEDULE_HOST_PORT=8001
MYSQL_HOST_PORT=3307
PMA_HOST_PORT=8082

# OpenAI — used by the AI Assistant in backend.php
OPENAI_API_KEY=
